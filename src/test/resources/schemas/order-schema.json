{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Order",
  "type": "object",
  "properties": {
    "id": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "productId": { "type": "integer" },
          "quantity": { "type": "integer" }
        },
        "required": ["id", "productId", "quantity"]
      }
    },
    "customerName": { "type": "string" },
    "created": { "type": "string" },
    "comment": { "type": ["string", "null"] },
    "invoice": { "type": ["string", "boolean", "null"] }
  },
  "required": ["id", "items", "customerName", "created"]
}
