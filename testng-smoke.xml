<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Grocery Store Smoke Suite" parallel="methods" thread-count="10">
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke" />
            </run>
        </groups>
        <packages>
            <package name="com.grocerystore.testcases.*" />
        </packages>
    </test>
</suite>
