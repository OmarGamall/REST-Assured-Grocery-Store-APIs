<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Grocery Store Regression Suite" parallel="methods" thread-count="10">
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="smoke" />
                <include name="regression" />
                <include name="e2e" />
            </run>
        </groups>
        <packages>
            <package name="com.grocerystore.testcases.*" />
        </packages>
    </test>
</suite>
